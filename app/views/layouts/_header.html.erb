<header class="bg-white border-b border-gray-100 sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
    <!-- ロゴ -->
    <% if user_signed_in? %>
      <%= link_to reviews_path, class: "flex items-center gap-2" do %>
        <span class="text-xl">🍽️</span>
        <span class="text-lg font-semibold text-gray-800">グルメレビュー</span>
      <% end %>
    <% else %>
      <%= link_to root_path, class: "flex items-center gap-2" do %>
        <span class="text-xl">🍽️</span>
        <span class="text-lg font-semibold text-gray-800">グルメレビュー</span>
      <% end %>
    <% end %>

    <!-- ナビゲーション -->
    <div class="flex items-center gap-3">
      <% if user_signed_in? %>
        <%= link_to "レビュー一覧", reviews_path,
            class: "text-sm text-gray-600 hover:text-gray-900 transition" %>
        <%= link_to "ユーザー", users_path,
            class: "text-sm text-gray-600 hover:text-gray-900 transition" %>
        <%= link_to "マップ", maps_path,
            class: "text-sm text-gray-600 hover:text-gray-900 transition" %>

        <!-- アバタードロップダウン -->
        <div class="relative" id="avatar-wrapper">
          <button id="avatar-btn" class="focus:outline-none">
            <% if current_user.avatar.attached? %>
              <%= image_tag current_user.avatar, class: "w-8 h-8 rounded-full object-cover hover:opacity-80 transition" %>
            <% else %>
              <div class="w-8 h-8 rounded-full bg-orange-200 flex items-center justify-center text-orange-600 font-bold text-sm hover:opacity-80 transition">
                <%= current_user.name.first.upcase %>
              </div>
            <% end %>
          </button>

          <!-- ドロップダウンメニュー -->
          <div id="dropdown-menu" class="hidden absolute right-0 mt-2 w-40 bg-white rounded-lg shadow-lg border border-gray-100 py-1 z-50">
            <%= link_to "プロフィール", user_path(current_user),
                class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50" %>
            <%= button_to "ログアウト", destroy_user_session_path, method: :delete,
                class: "w-full text-left px-4 py-2 text-sm text-red-500 hover:bg-gray-50" %>
          </div>
        </div>

      <% else %>
        <%= link_to "ログイン", new_user_session_path,
            class: "text-sm text-gray-600 hover:text-gray-900 transition" %>
        <%= link_to "新規登録", new_user_registration_path,
            class: "text-sm bg-orange-500 text-white px-4 py-2 rounded-lg hover:bg-orange-600 transition" %>
      <% end %>
    </div>
  </div>
</header>
