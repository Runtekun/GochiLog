<header class="bg-white border-b border-gray-100 sticky top-0 z-50" data-controller="mobile-menu">
  <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
    <!-- ロゴ -->
    <% if user_signed_in? %>
      <%= link_to reviews_path, class: "flex items-center gap-2" do %>
        <%= image_tag "ogp.png", class: "w-8 h-8 object-cover rounded" %>
        <span class="text-lg font-semibold text-gray-800">GochiLog</span>
      <% end %>
    <% else %>
      <%= link_to root_path, class: "flex items-center gap-2" do %>
        <%= image_tag "ogp.png", class: "w-8 h-8 object-cover rounded" %>
        <span class="text-lg font-semibold text-gray-800">GochiLog</span>
      <% end %>
    <% end %>

    <!-- PCナビゲーション -->
    <div class="hidden md:flex items-center gap-2">
      <% if user_signed_in? %>
        <%= link_to reviews_path, class: "flex items-center gap-1 text-sm text-gray-600 hover:text-gray-900 hover:bg-gray-100 px-3 py-2 rounded-lg transition" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
          ホーム
        <% end %>
        <%= link_to users_path, class: "flex items-center gap-1 text-sm text-gray-600 hover:text-gray-900 hover:bg-gray-100 px-3 py-2 rounded-lg transition" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          ユーザー
        <% end %>
        <%= link_to maps_path, class: "flex items-center gap-1 text-sm text-gray-600 hover:text-gray-900 hover:bg-gray-100 px-3 py-2 rounded-lg transition" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
          </svg>
          マップ
        <% end %>

        <!-- 通知ベルアイコン -->
        <%= link_to notifications_path, class: "relative inline-block hover:bg-gray-100 p-2 rounded-lg transition" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-gray-600 hover:text-gray-900 transition" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6 6 0 10-12 0v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
          </svg>
          <% if current_user.passive_notifications.where(checked: false).exists? %>
            <span class="absolute -top-1 -right-1 bg-red-500 text-white text-xs font-bold w-4 h-4 flex items-center justify-center rounded-full">!</span>
          <% end %>
        <% end %>

        <!-- アバタードロップダウン -->
        <div class="relative ml-2" id="avatar-wrapper">
          <button id="avatar-btn" class="focus:outline-none">
            <% if current_user.avatar.attached? %>
              <%= image_tag current_user.avatar, class: "w-8 h-8 rounded-full object-cover hover:opacity-80 transition" %>
            <% else %>
              <div class="w-8 h-8 rounded-full bg-orange-200 flex items-center justify-center text-orange-600 font-bold text-sm hover:opacity-80 transition">
                <%= current_user.name.first.upcase %>
              </div>
            <% end %>
          </button>

          <!-- ドロップダウンメニュー -->
          <div id="dropdown-menu" class="hidden absolute right-0 mt-2 w-40 bg-white rounded-lg shadow-lg border border-gray-100 py-1 z-50">
            <%= link_to "プロフィール", user_path(current_user),
                class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50" %>
            <%= button_to "ログアウト", destroy_user_session_path, method: :delete,
                class: "w-full text-left px-4 py-2 text-sm text-red-500 hover:bg-gray-50" %>
          </div>
        </div>

      <% else %>
        <%= link_to "ログイン", new_user_session_path,
            class: "text-sm text-gray-600 hover:text-gray-900 transition" %>
        <%= link_to "新規登録", new_user_registration_path,
            class: "text-sm bg-orange-500 text-white px-4 py-2 rounded-lg hover:bg-orange-600 transition" %>
      <% end %>
    </div>

    <!-- ハンバーガーボタン（スマホのみ） -->
    <button class="md:hidden focus:outline-none" data-action="click->mobile-menu#toggle">
      <!-- 開くアイコン -->
      <svg data-mobile-menu-target="open" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <!-- 閉じるアイコン -->
      <svg data-mobile-menu-target="close" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-700 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- モバイルメニュー -->
  <div data-mobile-menu-target="menu" class="hidden md:hidden border-t border-gray-100 bg-white">
    <div class="px-4 py-3 space-y-1">
      <% if user_signed_in? %>
        <%= link_to reviews_path, class: "flex items-center gap-2 py-2 text-sm text-gray-700 hover:text-orange-500 transition" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
          ホーム
        <% end %>
        <%= link_to users_path, class: "flex items-center gap-2 py-2 text-sm text-gray-700 hover:text-orange-500 transition" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          ユーザー
        <% end %>
        <%= link_to maps_path, class: "flex items-center gap-2 py-2 text-sm text-gray-700 hover:text-orange-500 transition" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
          </svg>
          マップ
        <% end %>
        <%= link_to notifications_path, class: "flex items-center gap-2 py-2 text-sm text-gray-700 hover:text-orange-500 transition" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6 6 0 10-12 0v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
          </svg>
          通知
          <% if current_user.passive_notifications.where(checked: false).exists? %>
            <span class="bg-red-500 text-white text-xs font-bold w-4 h-4 flex items-center justify-center rounded-full">!</span>
          <% end %>
        <% end %>
        <div class="border-t border-gray-100 pt-2 mt-2">
          <%= link_to "プロフィール", user_path(current_user),
              class: "block py-2 text-sm text-gray-700 hover:text-orange-500 transition" %>
          <%= button_to "ログアウト", destroy_user_session_path, method: :delete,
              class: "w-full text-left py-2 text-sm text-red-500 hover:text-red-600 transition" %>
        </div>
      <% else %>
        <%= link_to "ログイン", new_user_session_path,
            class: "block py-2 text-sm text-gray-700 hover:text-orange-500 transition" %>
        <%= link_to "新規登録", new_user_registration_path,
            class: "block py-2 text-sm font-semibold text-orange-500 hover:text-orange-600 transition" %>
      <% end %>
    </div>
  </div>
</header>
