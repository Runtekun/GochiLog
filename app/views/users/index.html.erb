<div class="max-w-4xl mx-auto px-4 py-8">
  <h1 class="text-2xl font-bold text-gray-800 mb-6">ユーザー一覧</h1>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <% @users.each do |user| %>
      <div class="bg-white rounded-xl shadow p-4 flex items-center gap-4">
        <%= link_to user_path(user), class: "flex items-center gap-4 flex-1 min-w-0" do %>
          <% if user.avatar.attached? %>
            <%= image_tag user.avatar, class: "w-14 h-14 rounded-full object-cover flex-shrink-0" %>
          <% else %>
            <div class="w-14 h-14 rounded-full bg-orange-200 flex items-center justify-center text-orange-600 font-bold text-xl flex-shrink-0">
              <%= user.name.first.upcase %>
            </div>
          <% end %>

          <div class="min-w-0">
            <p class="font-bold text-gray-800 truncate"><%= user.name %></p>
            <p class="text-sm text-gray-500 truncate"><%= user.bio.present? ? user.bio : "自己紹介はまだありません" %></p>
            <p class="text-xs text-gray-400 mt-1">
              フォロワー <%= user.followers.count %> · フォロー中 <%= user.following.count %>
            </p>
          </div>
        <% end %>

        <%= render "follows/follow_button", user: user %>
      </div>
    <% end %>
  </div>
</div>
