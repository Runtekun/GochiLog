<div class="max-w-lg mx-auto px-4 py-8">
  <h1 class="text-2xl font-bold text-gray-800 mb-6">プロフィール編集</h1>

  <%= form_with model: resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }, data: { turbo: false }, class: "space-y-4" do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">表示名</label>
      <%= f.text_field :name,
          class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-orange-400",
          placeholder: "名前を入力" %>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">自己紹介</label>
      <%= f.text_area :bio, rows: 4,
          class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-orange-400",
          placeholder: "自己紹介を書いてください（500文字以内）" %>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">プロフィール画像</label>
      <% if resource.avatar.attached? %>
        <div class="mb-2 flex items-center gap-3">
          <%= image_tag resource.avatar, class: "w-16 h-16 rounded-full object-cover" %>
          <p class="text-xs text-gray-400">新しい画像を選択すると変更されます</p>
        </div>
      <% end %>
      <%= f.file_field :avatar, accept: "image/*",
          class: "w-full border border-gray-300 rounded-lg px-3 py-2" %>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">メールアドレス</label>
      <%= f.email_field :email, autocomplete: "email",
          class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-orange-400" %>
    </div>

    <div class="flex gap-3">
      <%= f.submit "保存する",
          class: "flex-1 bg-orange-500 text-white py-3 rounded-lg font-medium hover:bg-orange-600 cursor-pointer" %>
      <%= link_to "キャンセル", user_path(current_user),
          class: "flex-1 text-center border border-gray-300 py-3 rounded-lg text-gray-600 hover:bg-gray-50" %>
    <y/div>
  <% end %>
</div>
