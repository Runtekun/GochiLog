<div class="bg-white rounded-xl shadow-md p-8 w-full max-w-md">
  <h1 class="text-2xl font-bold text-gray-800 mb-6 text-center">管理者ログイン</h1>

  <% if flash[:alert] %>
    <div class="mb-4 bg-red-100 text-red-700 px-4 py-3 rounded-lg text-sm">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <%= form_with url: admin_login_path, method: :post, class: "space-y-4" do |f| %>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">メールアドレス</label>
      <%= f.email_field :email, required: true,
          class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-400" %>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">パスワード</label>
      <%= f.password_field :password, required: true,
          class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-400" %>
    </div>
    <%= f.submit "ログイン",
        class: "w-full bg-gray-800 text-white py-3 rounded-lg font-medium hover:bg-gray-700 transition cursor-pointer" %>
  <% end %>
</div>
