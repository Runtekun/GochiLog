<div class="max-w-2xl mx-auto px-4 py-8">
  <%= link_to "← 一覧に戻る", reviews_path, class: "text-orange-500 hover:underline mb-6 block" %>

  <div class="bg-white rounded-xl shadow overflow-hidden">
    <% if @review.image.attached? %>
      <%= image_tag @review.image, class: "w-full h-64 object-cover" %>
    <% else %>
      <%= image_tag "ogp.png", class: "w-full h-64 object-cover" %>
    <% end %>

    <div class="p-6">
      <h1 class="text-2xl font-bold text-gray-800 mb-2"><%= @review.shop.name %></h1>
      <% if @review.shop.address.present? %>
        <p class="text-sm text-gray-500 mb-3">📍 <%= @review.shop.address %></p>
      <% end %>

      <% if @review.genre %>
        <span class="inline-block px-3 py-1 rounded-full text-sm font-medium mb-3 <%= genre_badge_class(@review.genre.name) %>">
          <%= @review.genre.name %>
        </span>
      <% end %>

      <div class="flex items-center mb-4">
        <% @review.rating.times do %>
          <span class="text-yellow-400 text-xl">★</span>
        <% end %>
        <% (5 - @review.rating).times do %>
          <span class="text-gray-300 text-xl">★</span>
        <% end %>
        <span class="text-gray-500 ml-2"><%= @review.rating %>/5</span>
      </div>

      <p class="text-gray-700 mb-6"><%= @review.body %></p>

      <div class="flex items-center justify-between border-t pt-4">
        <div class="flex items-center gap-2">
          <% if @review.user.avatar.attached? %>
            <%= image_tag @review.user.avatar, class: "w-8 h-8 rounded-full object-cover" %>
          <% else %>
            <div class="w-8 h-8 rounded-full bg-orange-200 flex items-center justify-center text-orange-600 font-bold text-sm">
              <%= @review.user.name.first.upcase %>
            </div>
          <% end %>
          <span class="text-gray-600"><%= @review.user.name %></span>
        </div>
        <div class="flex items-center gap-4">
          <%= render "likes/like_button", review: @review %>
          <span class="text-gray-400 text-sm"><%= @review.created_at.strftime("%Y年%m月%d日") %></span>
        </div>
      </div>

      <% if user_signed_in? && @review.user == current_user %>
        <div class="mt-4 flex gap-3">
          <%= link_to "編集", edit_review_path(@review),
              class: "border border-gray-300 text-gray-600 px-4 py-2 rounded-lg hover:bg-gray-50" %>
          <%= button_to "削除", review_path(@review), method: :delete,
              data: { turbo_confirm: "本当に削除しますか？" },
              class: "bg-red-500 text-white px-4 py-2 rounded-lg hover:bg-red-600" %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="mt-6 bg-white rounded-xl shadow p-6">
    <h2 class="font-bold text-gray-700 mb-4">コメント（<%= @review.comments.count %>）</h2>
    <div id="comments">
      <%= render @review.comments.order(created_at: :desc).includes(:user) %>
    </div>
    <% if user_signed_in? %>
      <%= render "comments/form", review: @review, comment: @review.comments.build %>
    <% end %>
  </div>

  <div class="mt-6">
    <h2 class="font-bold text-gray-700 mb-2">📍 店舗の場所</h2>
    <div id="map" class="w-full h-64 rounded-xl border border-gray-200"></div>
  </div>
</div>

<script>
function initMap() {
  const lat = <%= @review.shop.latitude %>;
  const lng = <%= @review.shop.longitude %>;
  const position = { lat, lng };

  const map = new google.maps.Map(document.getElementById("map"), {
    center: position,
    zoom: 15
  });

  new google.maps.Marker({
    position,
    map,
    title: "<%= j @review.shop.name %>"
  });
}
</script>
<script src="https://maps.googleapis.com/maps/api/js?key=<%= ENV['GOOGLE_MAPS_API_KEY'] %>&callback=initMap" async defer></script>
