<div class="max-w-2xl mx-auto px-4 py-8">
  <h1 class="text-2xl font-bold text-gray-800 mb-6">レビューを投稿</h1>

  <div class="mb-6">
    <p class="text-sm text-gray-500 mb-2">📍 店名を入力して候補を選ぶか、地図をクリックして場所を設定してください</p>
    <div class="relative">
      <div id="map" class="w-full h-72 rounded-xl border border-gray-200"></div>
      <button type="button" id="locate-btn"
        class="absolute bottom-3 left-3 z-10 bg-white border border-gray-300 rounded-full shadow-md p-2 hover:bg-gray-100 transition"
        title="現在地を表示">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="3" fill="currentColor" stroke="none"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 2v2m0 16v2M2 12h2m16 0h2M4.93 4.93l1.41 1.41m11.32 11.32 1.41 1.41M4.93 19.07l1.41-1.41m11.32-11.32 1.41-1.41"/>
        </svg>
      </button>
    </div>
  </div>

  <%= form_with model: @review, data: { turbo: false, controller: "loading-button", action: "submit->loading-button#submit" }, class: "space-y-4" do |f| %>
    <input type="hidden" name="latitude" id="latitude">
    <input type="hidden" name="longitude" id="longitude">
    <input type="hidden" name="address" id="address">
    <input type="hidden" name="shop_photo_url" id="shop_photo_url">

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">
        店名 <span class="text-red-500">*</span>
      </label>
      <input type="text" name="shop_name" id="shop_name" required
             class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-orange-400"
             placeholder="例：〇〇ラーメン" autocomplete="off">
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">
        評価 <span class="text-red-500">*</span>
      </label>
      <%= f.select :rating,
          [["★★★★★ (5)", 5], ["★★★★☆ (4)", 4], ["★★★☆☆ (3)", 3], ["★★☆☆☆ (2)", 2], ["★☆☆☆☆ (1)", 1]],
          { include_blank: "選択してください" },
          { required: true, class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-orange-400" } %>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">ジャンル</label>
      <%= f.collection_select :genre_id, @genres, :id, :name,
          { include_blank: "選択してください" },
          { class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-orange-400" } %>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">
        コメント <span class="text-red-500">*</span>
      </label>
      <%= f.text_area :body, rows: 4, required: true,
          class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-orange-400",
          placeholder: "お店の感想を書いてください" %>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">写真</label>
      <p class="text-xs text-gray-400 mb-1">未選択の場合は店舗の写真が自動で使われます</p>
      <%= f.file_field :image, accept: "image/*",
          class: "w-full border border-gray-300 rounded-lg px-3 py-2" %>
    </div>

    <div id="location-warning" class="hidden bg-yellow-100 border border-yellow-400 text-yellow-700 px-4 py-2 rounded text-sm">
      ⚠️ 地図をクリックして店の場所を設定してください
    </div>

    <button type="submit" onclick="return validateLocation()"
            data-loading-button-target="button"
            class="w-full bg-orange-500 text-white py-3 rounded-lg font-medium hover:bg-orange-600 transition">
      投稿する
    </button>
  <% end %>
</div>

<script>
let map, marker;

function initMap() {
  map = new google.maps.Map(document.getElementById("map"), {
    center: { lat: 35.6812, lng: 139.7671 },
    zoom: 13
  });

  document.getElementById("locate-btn").addEventListener("click", () => {
    if (!navigator.geolocation) {
      alert("このブラウザは位置情報に対応していません。");
      return;
    }
    navigator.geolocation.getCurrentPosition(
      (position) => {
        const pos = {
          lat: position.coords.latitude,
          lng: position.coords.longitude
        };
        map.panTo(pos);
        map.setZoom(16);
      },
      () => {
        alert("現在地を取得できませんでした。位置情報の許可を確認してください。");
      },
      { timeout: 30000, maximumAge: 300000, enableHighAccuracy: false }
    );
  });

  const geocoder = new google.maps.Geocoder();

  const autocomplete = new google.maps.places.Autocomplete(
    document.getElementById("shop_name"),
    { types: ["establishment"], fields: ["name", "geometry", "formatted_address", "photos"] }
  );

  autocomplete.addListener("place_changed", () => {
    const place = autocomplete.getPlace();
    if (!place.geometry) return;

    document.getElementById("shop_name").value = place.name;
    document.getElementById("address").value = place.formatted_address || "";

    if (place.photos && place.photos.length > 0) {
      const photoUrl = place.photos[0].getUrl({ maxWidth: 800, maxHeight: 600 });
      document.getElementById("shop_photo_url").value = photoUrl;
    } else {
      document.getElementById("shop_photo_url").value = "";
    }

    const lat = place.geometry.location.lat();
    const lng = place.geometry.location.lng();

    document.getElementById("latitude").value = lat;
    document.getElementById("longitude").value = lng;

    if (marker) marker.setMap(null);
    marker = new google.maps.Marker({
      position: { lat, lng },
      map: map,
      animation: google.maps.Animation.DROP
    });

    map.panTo({ lat, lng });
    map.setZoom(16);
    document.getElementById("location-warning").classList.add("hidden");
  });

  map.addListener("click", (event) => {
    const lat = event.latLng.lat();
    const lng = event.latLng.lng();

    document.getElementById("latitude").value = lat;
    document.getElementById("longitude").value = lng;

    if (marker) marker.setMap(null);
    marker = new google.maps.Marker({
      position: { lat, lng },
      map: map,
      animation: google.maps.Animation.DROP
    });

    document.getElementById("location-warning").classList.add("hidden");

    geocoder.geocode({ location: { lat, lng } }, (results, status) => {
      if (status === "OK" && results[0]) {
        document.getElementById("address").value = results[0].formatted_address;
      }
    });
  });
}

function validateLocation() {
  if (!document.getElementById("latitude").value) {
    document.getElementById("location-warning").classList.remove("hidden");
    return false;
  }
  return true;
}
</script>

<script src="https://maps.googleapis.com/maps/api/js?key=<%= ENV['GOOGLE_MAPS_API_KEY'] %>&libraries=places&callback=initMap" async defer></script>
