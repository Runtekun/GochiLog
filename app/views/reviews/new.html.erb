<div class="max-w-2xl mx-auto px-4 py-8">
  <h1 class="text-2xl font-bold text-gray-800 mb-6">レビューを投稿</h1>

  <%= form_with model: @review, data: { turbo: false }, class: "space-y-4" do |f| %>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">
        店名 <span class="text-red-500">*</span>
      </label>
      <input type="text" name="shop_name" required
             class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-orange-400"
             placeholder="例：〇〇ラーメン">
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">
        緯度 <span class="text-red-500">*</span>
      </label>
      <input type="text" name="latitude" required
             class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-orange-400"
             placeholder="例:35.6812">
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">
        経度 <span class="text-red-500">*</span>
      </label>
      <input type="text" name="longitude" required
             class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-orange-400"
             placeholder="例:139.7671">
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">
        評価 <span class="text-red-500">*</span>
      </label>
      <%= f.select :rating,
          [["★★★★★ (5)", 5], ["★★★★☆ (4)", 4], ["★★★☆☆ (3)", 3], ["★★☆☆☆ (2)", 2], ["★☆☆☆☆ (1)", 1]],
          { include_blank: "選択してください" },
          { required: true, class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-orange-400" } %>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">
        コメント <span class="text-red-500">*</span>
      </label>
      <%= f.text_area :body, rows: 4, required: true,
          class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-orange-400",
          placeholder: "お店の感想を書いてください" %>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">写真</label>
      <%= f.file_field :image, accept: "image/*",
          class: "w-full border border-gray-300 rounded-lg px-3 py-2" %>
    </div>

    <button type="submit"
            class="w-full bg-orange-500 text-white py-3 rounded-lg font-medium hover:bg-orange-600 transition">
      投稿する
    </button>
  <% end %>
</div>
