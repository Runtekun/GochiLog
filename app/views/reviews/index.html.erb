<div class="max-w-6xl mx-auto px-4 py-8">
  <div class="flex items-center gap-4 mb-6">
    <h1 class="text-2xl font-bold text-gray-800 shrink-0">レビュー一覧</h1>

    <%= search_form_for @q, url: reviews_path, html: { class: "flex-1 flex justify-center" } do |f| %>
      <div class="flex gap-2 w-full max-w-md">
        <%= f.search_field :shop_name_or_user_name_or_genre_name_cont,
            placeholder: "店名・ユーザー・ジャンル",
            list: "search-suggestions",
            autocomplete: "off",
            class: "flex-1 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400" %>
        <%= f.submit "検索",
            class: "bg-orange-500 text-white px-3 py-2 rounded-lg text-sm hover:bg-orange-600 transition cursor-pointer" %>
      </div>
      <datalist id="search-suggestions">
        <% @autocomplete_items.each do |item| %>
          <option value="<%= item %>">
        <% end %>
      </datalist>
    <% end %>

    <%= link_to "＋ レビューを投稿", new_review_path,
        class: "shrink-0 bg-orange-500 text-white px-4 py-2 rounded-lg hover:bg-orange-600 transition" %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% @reviews.each do |review| %>
      <div class="relative bg-white rounded-xl shadow hover:shadow-md transition overflow-hidden">
        <%= link_to review_path(review), class: "block" do %>
          <div class="relative">
            <% if review.image.attached? %>
              <%= image_tag review.image, class: "w-full h-48 object-cover" %>
            <% else %>
              <div class="w-full h-48 bg-gray-100 flex items-center justify-center text-gray-400 text-4xl">🍽️</div>
            <% end %>
            <% if review.genre %>
              <span class="absolute top-2 left-2 px-2 py-0.5 rounded-full text-xs font-medium <%= genre_badge_class(review.genre.name) %>">
                <%= review.genre.name %>
              </span>
            <% end %>
          </div>

          <div class="p-4">
            <h2 class="font-bold text-gray-800 text-lg mb-1"><%= review.shop.name %></h2>

            <div class="flex items-center mb-2">
              <% review.rating.times do %>
                <span class="text-yellow-400">★</span>
              <% end %>
              <% (5 - review.rating).times do %>
                <span class="text-gray-300">★</span>
              <% end %>
              <span class="text-gray-500 text-sm ml-1">(<%= review.rating %>)</span>
            </div>

            <p class="text-gray-600 text-sm line-clamp-2"><%= review.body %></p>

            <div class="mt-3 flex items-center justify-between">
              <div class="w-24"></div>
              <span class="text-xs text-gray-400"><%= review.created_at.strftime("%Y/%m/%d") %></span>
            </div>
            <div class="h-8"></div>
          </div>
        <% end %>

        <!-- いいねボタン（レビューリンクの外に配置） -->
        <div class="absolute bottom-4 right-4 z-10">
          <%= render "likes/like_button", review: review %>
        </div>

        <!-- ユーザーアイコン（レビューリンクの外に配置） -->
        <%= link_to user_path(review.user), class: "absolute bottom-4 left-4 flex items-center gap-2 z-10" do %>
          <% if review.user.avatar.attached? %>
            <%= image_tag review.user.avatar, class: "w-6 h-6 rounded-full object-cover" %>
          <% else %>
            <div class="w-6 h-6 rounded-full bg-orange-200 flex items-center justify-center text-orange-600 font-bold text-xs">
              <%= review.user.name.first.upcase %>
            </div>
          <% end %>
          <span class="text-xs text-gray-500 hover:text-gray-800 transition"><%= review.user.name %></span>
        <% end %>
      </div>
    <% end %>
  </div>
</div>