<div class="max-w-6xl mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-800">レビュー一覧</h1>
    <%= link_to "＋ レビューを投稿", new_review_path,
        class: "bg-orange-500 text-white px-4 py-2 rounded-lg hover:bg-orange-600 transition" %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% @reviews.each do |review| %>
      <%= link_to review_path(review), class: "block bg-white rounded-xl shadow hover:shadow-md transition overflow-hidden" do %>
        <% if review.image.attached? %>
          <%= image_tag review.image, class: "w-full h-48 object-cover" %>
        <% else %>
          <div class="w-full h-48 bg-gray-100 flex items-center justify-center text-gray-400 text-4xl">🍽️</div>
        <% end %>

        <div class="p-4">
          <h2 class="font-bold text-gray-800 text-lg mb-1"><%= review.shop.name %></h2>

          <div class="flex items-center mb-2">
            <% review.rating.times do %>
              <span class="text-yellow-400">★</span>
            <% end %>
            <% (5 - review.rating).times do %>
              <span class="text-gray-300">★</span>
            <% end %>
            <span class="text-gray-500 text-sm ml-1">(<%= review.rating %>)</span>
          </div>

          <p class="text-gray-600 text-sm line-clamp-2"><%= review.body %></p>

          <div class="mt-3 flex items-center justify-between text-xs text-gray-400">
            <span><%= review.user.name %></span>
            <span><%= review.created_at.strftime("%Y/%m/%d") %></span>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
</div>